{
  "name": "galletas-online",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:wrangler": "wrangler pages dev .next --compatibility-date=2024-01-01 --binding DB=galletas-db",
    "build": "next build",
    "pages:build": "npx @cloudflare/next-on-pages",
    "start": "next start",
    "lint": "eslint",
    "preview": "wrangler pages dev .vercel/output/static",
    "deploy": "npm run pages:build && wrangler pages deploy .vercel/output/static",
    "wrangler": "node scripts/wrangler-wrapper.js"
  },
  "bin": {
    "wrangler": "./scripts/wrangler-wrapper.js"
  },
  "dependencies": {
    "googleapis": "^170.1.0",
    "next": "^15.5.0",
    "nodemailer": "^7.0.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1",
    "eslint": "^9",
    "eslint-config-next": "^15.5.0",
    "wrangler": "^3"
  }
}