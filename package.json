{
  "name": "galletas-online",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:wrangler": "wrangler pages dev .next --compatibility-date=2024-01-01 --binding DB=galletas-db",
    "build": "npx @cloudflare/next-on-pages",
    "start": "next start",
    "lint": "eslint",
    "preview": "wrangler pages dev .vercel/output/static",
    "deploy": "npm run build && wrangler pages deploy .vercel/output/static"
  },
  "dependencies": {
    "googleapis": "^170.1.0",
    "next": "16.1.3",
    "nodemailer": "^7.0.12",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1",
    "eslint": "^9",
    "eslint-config-next": "16.1.3",
    "wrangler": "^3"
  }
}