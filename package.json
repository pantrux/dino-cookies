{
  "name": "galletas-online",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "dev:wrangler": "wrangler pages dev .next --compatibility-date=2024-01-01 --binding DB=galletas-db",
    "build": "next build",
    "pages:build": "npx @cloudflare/next-on-pages",
    "start": "next start",
    "lint": "eslint",
    "preview": "wrangler pages dev .vercel/output/static",
    "deploy": "npm run pages:build && wrangler pages deploy .vercel/output/static",
    "wrangler": "node scripts/wrangler-wrapper.js",
    "qa:visual:screenshots": "node docs/redesign/scripts/capture_audit_screenshots.mjs"
  },
  "bin": {
    "wrangler": "./scripts/wrangler-wrapper.js"
  },
  "dependencies": {
    "next": "15.5.0",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "1.13.16",
    "@eslint/eslintrc": "^3.3.5",
    "eslint": "9.39.2",
    "eslint-config-next": "15.5.0",
    "playwright": "^1.54.2",
    "wrangler": "^3"
  }
}
